<?xml version="1.0"?>
<ruleset name="PowerNews PHPMD Rules"
         xmlns="http://pmd.sf.net/ruleset/1.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0 http://pmd.sf.net/ruleset_xml_schema.xsd"
         xsi:noNamespaceSchemaLocation="http://pmd.sf.net/ruleset_xml_schema.xsd">

    <description>PowerNews Code Quality Rules - angepasst für Legacy PHP-Code</description>

    <!-- DTO-Datei ausschließen (Konstruktoren haben viele Parameter by design) -->
    <exclude-pattern>*/dto.inc.php</exclude-pattern>

    <!-- Clean Code Rules -->
    <rule ref="rulesets/cleancode.xml">
        <!-- Legacy-Code verwendet statische Zugriffe -->
        <exclude name="StaticAccess"/>
        <!-- Superglobals werden durch validation.inc.php zentral abgefangen -->
        <exclude name="Superglobals"/>
        <!-- Legacy-Code hat else-Blöcke -->
        <exclude name="ElseExpression"/>
        <!-- MissingImport für Legacy-Code ohne Namespaces ausschließen -->
        <exclude name="MissingImport"/>
    </rule>

    <!-- Code Size Rules - Basis ohne die Regeln die wir anpassen -->
    <rule ref="rulesets/codesize.xml">
        <exclude name="TooManyPublicMethods"/>
        <exclude name="ExcessivePublicCount"/>
        <!-- Diese Regeln werden unten mit angepassten Thresholds hinzugefügt -->
        <exclude name="CyclomaticComplexity"/>
        <exclude name="NPathComplexity"/>
        <exclude name="ExcessiveMethodLength"/>
        <exclude name="ExcessiveClassLength"/>
        <exclude name="ExcessiveClassComplexity"/>
        <exclude name="ExcessiveParameterList"/>
    </rule>

    <!-- Zyklomatische Komplexität (Legacy-Code hat oft hohe Werte) -->
    <rule ref="rulesets/codesize.xml/CyclomaticComplexity">
        <properties>
            <property name="reportLevel" value="25"/>
        </properties>
    </rule>

    <!-- NPath Komplexität (Legacy-Code hat viele Verzweigungen) -->
    <!-- Höchste Werte: listpermissions()=16387, news()=5185, archive()=3024 -->
    <rule ref="rulesets/codesize.xml/NPathComplexity">
        <properties>
            <property name="minimum" value="20000"/>
        </properties>
    </rule>

    <!-- Methodenlänge -->
    <rule ref="rulesets/codesize.xml/ExcessiveMethodLength">
        <properties>
            <property name="minimum" value="150"/>
        </properties>
    </rule>

    <!-- Klassenlänge -->
    <rule ref="rulesets/codesize.xml/ExcessiveClassLength">
        <properties>
            <property name="minimum" value="1500"/>
        </properties>
    </rule>

    <!-- Klassenkomplexität -->
    <rule ref="rulesets/codesize.xml/ExcessiveClassComplexity">
        <properties>
            <property name="maximum" value="100"/>
        </properties>
    </rule>

    <!-- Parameterliste (Legacy-Methoden/DTOs haben oft viele Parameter) -->
    <rule ref="rulesets/codesize.xml/ExcessiveParameterList">
        <properties>
            <!-- 22 erlaubt alle aktuellen Methoden inkl. DTO-Konstruktoren -->
            <property name="minimum" value="22"/>
        </properties>
    </rule>

    <!-- Controversial Rules -->
    <rule ref="rulesets/controversial.xml">
        <!-- CamelCase nicht für Legacy-Code erzwingen -->
        <exclude name="CamelCaseClassName"/>
        <exclude name="CamelCaseMethodName"/>
        <exclude name="CamelCaseParameterName"/>
        <exclude name="CamelCasePropertyName"/>
        <exclude name="CamelCaseVariableName"/>
        <!-- Superglobals - werden durch validation.inc.php zentral abgefangen -->
        <exclude name="Superglobals"/>
    </rule>

    <!-- Design Rules -->
    <rule ref="rulesets/design.xml">
        <!-- Exit ist in Legacy-Code üblich -->
        <exclude name="ExitExpression"/>
        <!-- Eval wird nicht verwendet, aber ausschließen -->
        <exclude name="EvalExpression"/>
    </rule>

    <!-- Naming Rules -->
    <rule ref="rulesets/naming.xml">
        <!-- Kurze Variablennamen für Legacy-Code erlauben -->
        <exclude name="ShortVariable"/>
        <!-- Lange Variablennamen erlauben -->
        <exclude name="LongVariable"/>
        <!-- Kurze Methodennamen erlauben -->
        <exclude name="ShortMethodName"/>
    </rule>

    <!-- Unused Code Rules -->
    <rule ref="rulesets/unusedcode.xml">
        <!-- Unused parameters in Legacy-Code -->
        <exclude name="UnusedFormalParameter"/>
    </rule>

</ruleset>
