{
    "name": "powerscripts/powernews",
    "description": "PowerNews - PHP and MySQL based news script",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "PowerScripts",
            "homepage": "https://www.powerscripts.org"
        }
    ],
    "homepage": "https://github.com/schubertnico/PowerNews",
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "PowerNews\\": "src/"
        }
    },
    "scripts": {
        "phpstan": "phpstan analyse --memory-limit=512M",
        "rector": "rector process",
        "rector:dry": "rector process --dry-run"
    },
    "config": {
        "platform": {
            "php": "8.4"
        },
        "sort-packages": true
    }
}
