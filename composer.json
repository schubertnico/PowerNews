{
    "name": "powerscripts/powernews",
    "description": "PowerNews - PHP and MySQL based news script",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "PowerScripts",
            "homepage": "https://www.powerscripts.org"
        }
    ],
    "homepage": "https://github.com/schubertnico/PowerNews",
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.92",
        "infection/infection": "*",
        "phpmd/phpmd": "^2.15",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^2.0",
        "vimeo/psalm": "^6.5"
    },
    "autoload": {
        "psr-4": {
            "PowerNews\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PowerNews\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite Unit",
        "test:feature": "phpunit --testsuite Feature",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "psalm": "psalm",
        "phpmd": "phpmd pninc,pnadmin text phpmd.xml --exclude vendor,tests",
        "phpmd:html": "phpmd pninc,pnadmin html phpmd.xml --exclude vendor,tests --reportfile phpmd-report.html",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "infection": "echo 'Infection requires Xdebug or PCOV. Run in Docker: docker compose exec web composer infection:run'",
        "infection:run": "infection --threads=4",
        "rector": "rector process",
        "rector:dry": "rector process --dry-run",
        "quality:check": [
            "@phpstan",
            "@psalm",
            "@phpmd",
            "@cs"
        ],
        "quality:fix": [
            "@rector",
            "@cs:fix"
        ],
        "security:check": [
            "@phpstan",
            "@psalm",
            "@test:unit"
        ],
        "security:full": [
            "@phpstan",
            "@psalm",
            "@test"
        ]
    },
    "config": {
        "platform": {
            "php": "8.4"
        },
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true
        }
    }
}
